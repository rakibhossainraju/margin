{
  "manifest_version": 3,
  "name": "Margin",
  "version": "0.1.0",
  "description": "Activates on PDF documents and verifies content/background messaging.",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*.pdf*", "file://*/*.pdf*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Margin"
  },
  "commands": {
    "get-selection": {
      "suggested_key": { "default": "Ctrl+Shift+Y"},
      "description": "Fetch selected text instantly"
    }
  }
}
