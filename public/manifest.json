{
  "manifest_version": 3,
  "name": "Margin",
  "version": "0.1.0",
  "description": "Activates on PDF documents and verifies content/background messaging.",
  "permissions": ["activeTab", "scripting", "declarativeNetRequest"],
  "host_permissions": [
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Margin"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "pdf.worker.mjs",
        "cmaps/*",
        "standard_fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "reload-extension": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Reload the extension"
    }
  }
}

